@startuml
skinparam backgroundColor white
skinparam sequenceArrowThickness 2

actor User
participant ":PharmaTracker" as PT
participant ":Parser" as Parser
participant ":DispenseCommand" as Cmd
participant ":Inventory" as Inv
participant ":CustomerList" as CustList

User -> PT : run()
PT -> Parser : parse("dispense 1 q/20 c/1")
Parser --> PT : new DispenseCommand(1, 20, 1)
PT -> Cmd : execute(inventory, ui, customerList)
Cmd -> Inv : getMedications()
Inv --> Cmd : medications

alt invalid medication index
    Cmd --> User : "Invalid index."
else quantity exceeds stock
    Cmd --> User : "Insufficient stock."
else invalid customer index
    Cmd --> User : "Invalid customer index."
else all valid
    Cmd -> Inv : getMedication(0)
    Inv --> Cmd : med
    Cmd -> Inv : med.setQuantity(currentQty - 20)
    alt c/ flag provided
        Cmd -> CustList : getCustomer(0)
        CustList --> Cmd : customer
        Cmd -> CustList : customer.addDispensingHistory(record)
    end
    Cmd --> User : success message
end
@enduml
